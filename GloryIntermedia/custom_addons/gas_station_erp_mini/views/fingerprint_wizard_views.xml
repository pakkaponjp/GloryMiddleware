<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_fingerprint_enroll_wizard_form" model="ir.ui.view">
            <field name="name">fingerprint.enroll.wizard.form</field>
            <field name="model">fingerprint.enroll.wizard</field>
            <field name="arch" type="xml">
                <form string="Enroll Fingerprint">

                    <!-- ── Step: confirm (capture succeeded) ── -->
                    <div invisible="step != 'confirm'">
                        <div class="alert alert-success d-flex align-items-center gap-2 mb-3" role="alert">
                            <i class="fa fa-check-circle fa-2x text-success" title="Capture successful"/>
                            <div>
                                <strong>Fingerprint captured!</strong><br/>
                                <field name="status_message" readonly="1" nolabel="1"/>
                            </div>
                        </div>
                        <group>
                            <field name="staff_name"    readonly="1" string="Staff Member"/>
                            <field name="template_size" readonly="1" string="Template Size (bytes)"/>
                            <field name="step"          invisible="1"/>
                        </group>
                    </div>

                    <!-- ── Step: error (capture failed) ── -->
                    <div invisible="step != 'error'">
                        <div class="alert alert-danger d-flex align-items-center gap-2 mb-3" role="alert">
                            <i class="fa fa-times-circle fa-2x text-danger" title="Capture failed"/>
                            <div>
                                <strong>Capture failed</strong><br/>
                                <field name="error_message" readonly="1" nolabel="1"/>
                            </div>
                        </div>
                        <group>
                            <field name="staff_name" readonly="1" string="Staff Member"/>
                            <field name="step"       invisible="1"/>
                        </group>
                        <div class="text-muted small mt-2">
                            <i class="fa fa-info-circle" title="Info"/>
                            Make sure the fingerprint service is running and the
                            sensor is connected, then click <b>Try Again</b>.
                        </div>
                    </div>

                    <!-- Hidden fields -->
                    <field name="template_b64" invisible="1"/>
                    <field name="staff_id"     invisible="1"/>
                    <field name="is_reenroll"  invisible="1"/>

                    <footer>
                        <!-- confirm -->
                        <button name="action_save"
                                string="Save Fingerprint"
                                type="object"
                                class="btn-success"
                                icon="fa-save"
                                invisible="step != 'confirm'"/>
                        <button name="action_retry"
                                string="Scan Again"
                                type="object"
                                class="btn-secondary"
                                icon="fa-refresh"
                                invisible="step != 'confirm'"/>

                        <!-- error -->
                        <button name="action_retry"
                                string="Try Again"
                                type="object"
                                class="btn-warning"
                                icon="fa-refresh"
                                invisible="step != 'error'"/>

                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>

                </form>
            </field>
        </record>

    </data>
</odoo>