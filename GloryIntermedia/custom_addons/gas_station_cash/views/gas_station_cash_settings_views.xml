<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <!--
        ============================================================
        Gas Station Cash — Settings tab inside Odoo Settings
        ============================================================
        -->
        <record id="res_config_settings_view_form_inherit_glory" model="ir.ui.view">
            <field name="name">res.config.settings.view.form.inherit.glory</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="base.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//form" position="inside">
                    <app data-string="Gas Station Cash" string="Gas Station Cash" name="gas_station_cash">

                        <!-- Glory Control Panel -->
                        <block title="Glory Cash Recycler Settings" name="glory_settings_block">
                            <setting id="glory_control_panel_setting"
                                      string="Glory Control Panel"
                                      help="Control and monitor the Glory Cash Recycler machine">
                                <div class="content-group">
                                    <div class="mt16">
                                        <widget name="glory_control_buttons"/>
                                    </div>
                                </div>
                            </setting>
                        </block>

                        <!-- POS Integration -->
                        <block title="POS Integration" name="pos_integration_block">
                            <setting id="pos_vendor_setting"
                                      string="POS Vendor"
                                      help="Select which external POS vendor the middleware talks to (Local, FirstPro or FlowCo)">
                                <field name="gas_pos_vendor"/>
                            </setting>
                        </block>

                        <!-- Collection Settings -->
                        <block title="Collection Settings" name="collection_settings_block">

                            <setting id="collect_close_shift_setting"
                                      string="Collect on Close Shift"
                                      help="If enabled, cash will be collected into the collection box when the POS calls CloseShift. Auto-enables End-of-Day collection.">
                                <field name="gas_collect_on_close_shift" widget="boolean_toggle"/>
                            </setting>

                            <setting id="collect_end_of_day_setting"
                                      string="Collect on End-of-Day"
                                      help="If enabled, cash will be collected at End-of-Day. Automatically enabled when Collect on Close Shift is on.">
                                <field name="gas_collect_on_end_of_day" widget="boolean_toggle" readonly="gas_collect_on_close_shift"/>
                            </setting>

                            <!-- Hidden field for replenished state -->
                            <field name="gas_float_replenished" invisible="1"/>

                            <setting id="leave_float_setting"
                                      string="Leave Float"
                                      help="If enabled, the machine will keep the configured float denomination after collection. Requires replenishment first.">
                                <!-- disabled when not replenished -->
                                <field name="gas_leave_float" widget="boolean_toggle"
                                       readonly="not gas_float_replenished"/>
                                <span invisible="gas_float_replenished"
                                      class="text-muted ms-2"
                                      style="font-size:0.85em;">
                                    (Replenish cash first to enable)
                                </span>
                            </setting>

                            <setting id="float_mode_setting"
                                      string="Leave Float Mode"
                                      help="Choose how the machine determines which denominations to keep as float."
                                      invisible="not gas_leave_float">
                                <field name="gas_float_mode" widget="radio"/>
                            </setting>

                            <!-- Denomination grid — visible when Leave Float = ON, locked (readonly) -->
                            <setting id="float_denomination_setting"
                                      string="Denomination for Float"
                                      help="Set the quantity of each denomination to keep as float in the machine"
                                      invisible="not gas_leave_float">
                                <div class="content-group" style="width:100%;">
                                    <div class="row mt8 mb4"><div class="col-12"><strong>Notes / ธนบัตร</strong></div></div>
                                    <div class="row" style="gap:0.4rem 0;">
                                        <div class="col-4 d-flex align-items-center" style="gap:0.5rem;"><span style="min-width:65px;">฿1,000</span><field name="gas_float_note_1000" style="width:80px;" readonly="gas_leave_float"/></div>
                                        <div class="col-4 d-flex align-items-center" style="gap:0.5rem;"><span style="min-width:65px;">฿500</span><field name="gas_float_note_500" style="width:80px;" readonly="gas_leave_float"/></div>
                                        <div class="col-4 d-flex align-items-center" style="gap:0.5rem;"><span style="min-width:65px;">฿100</span><field name="gas_float_note_100" style="width:80px;" readonly="gas_leave_float"/></div>
                                        <div class="col-4 d-flex align-items-center" style="gap:0.5rem;"><span style="min-width:65px;">฿50</span><field name="gas_float_note_50" style="width:80px;" readonly="gas_leave_float"/></div>
                                        <div class="col-4 d-flex align-items-center" style="gap:0.5rem;"><span style="min-width:65px;">฿20</span><field name="gas_float_note_20" style="width:80px;" readonly="gas_leave_float"/></div>
                                    </div>
                                    <div class="row mt12 mb4"><div class="col-12"><strong>Coins / เหรียญ</strong></div></div>
                                    <div class="row" style="gap:0.4rem 0;">
                                        <div class="col-4 d-flex align-items-center" style="gap:0.5rem;"><span style="min-width:65px;">฿10</span><field name="gas_float_coin_10" style="width:80px;" readonly="gas_leave_float"/></div>
                                        <div class="col-4 d-flex align-items-center" style="gap:0.5rem;"><span style="min-width:65px;">฿5</span><field name="gas_float_coin_5" style="width:80px;" readonly="gas_leave_float"/></div>
                                        <div class="col-4 d-flex align-items-center" style="gap:0.5rem;"><span style="min-width:65px;">฿2</span><field name="gas_float_coin_2" style="width:80px;" readonly="gas_leave_float"/></div>
                                        <div class="col-4 d-flex align-items-center" style="gap:0.5rem;"><span style="min-width:65px;">฿1</span><field name="gas_float_coin_1" style="width:80px;" readonly="gas_leave_float"/></div>
                                        <div class="col-4 d-flex align-items-center" style="gap:0.5rem;"><span style="min-width:65px;">฿0.50</span><field name="gas_float_coin_050" style="width:80px;" readonly="gas_leave_float"/></div>
                                        <div class="col-4 d-flex align-items-center" style="gap:0.5rem;"><span style="min-width:65px;">฿0.25</span><field name="gas_float_coin_025" style="width:80px;" readonly="gas_leave_float"/></div>
                                    </div>
                                </div>
                            </setting>

                            <!-- Float Amount — read-only, visible when Leave Float = ON -->
                            <setting id="float_amount_setting"
                                      string="Float Amount"
                                      help="Total float amount calculated from denomination quantities above (read-only)"
                                      invisible="not gas_leave_float">
                                <field name="gas_float_amount" readonly="1"/>
                            </setting>

                        </block>

                        <!-- Watermark Settings — full-width vertical layout -->
                        <block title="Denomination Watermark Settings" name="watermark_settings_block">

                            <!--
                                Use a plain div row inside block (no <setting> wrapper) so content
                                spans the full block width without Odoo's 2-pane left/right split.
                            -->
                            <div class="row">
                                <div class="col-12">

                                    <!-- Instruction banner -->
                                    <div style="background:#f8f9fa;border-radius:4px;border-left:4px solid #adb5bd;padding:10px 14px;margin-bottom:16px;line-height:1.8;">
                                        🔴 <strong>Near Empty</strong> — qty ต่ำกว่าค่านี้ → แนะนำเติมเงิน (Replenish)
                                        &#160;&#160;|&#160;&#160;
                                        🟡 <strong>Near Full</strong> — qty สูงกว่าค่านี้ → แนะนำ Collect หรือ Exchange
                                        <br/>
                                        <span style="font-size:0.85em;color:#6c757d;">
                                            Near Full default โหลดจาก stacker capacity ใน odoo.conf · ตั้ง 0 = ปิดการแจ้งเตือน denomination นั้น
                                        </span>
                                    </div>

                                    <!-- ── NOTES ─────────────────────────────────── -->
                                    <div style="font-weight:600;color:#495057;font-size:0.9em;margin-bottom:6px;padding-bottom:4px;border-bottom:2px solid #dee2e6;">
                                        Notes / ธนบัตร
                                    </div>
                                    <table style="width:100%;border-collapse:collapse;table-layout:fixed;margin-bottom:20px;">
                                        <colgroup>
                                            <col style="width:18%;"/><!-- denomination label -->
                                            <col style="width:41%;"/><!-- low input + % -->
                                            <col style="width:41%;"/><!-- high input + % -->
                                        </colgroup>
                                        <thead>
                                            <tr style="background:#f8f9fa;font-size:0.82em;color:#6c757d;">
                                                <th style="padding:6px 10px;text-align:left;border-bottom:1px solid #dee2e6;">Denomination</th>
                                                <th style="padding:6px 10px;text-align:left;border-bottom:1px solid #dee2e6;">🔴 Near Empty (Low)</th>
                                                <th style="padding:6px 10px;text-align:left;border-bottom:1px solid #dee2e6;">🟡 Near Full (High)</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr style="border-bottom:1px solid #f0f0f0;">
                                                <td style="padding:6px 10px;font-weight:500;">฿1,000</td>
                                                <td style="padding:4px 10px;"><div style="display:flex;align-items:center;gap:6px;"><field name="gas_wm_low_note_1000" style="width:90px;" nolabel="1"/><field name="gas_wm_low_note_1000_pct" style="width:52px;color:#6c757d;font-size:0.85em;" nolabel="1" readonly="1"/></div></td>
                                                <td style="padding:4px 10px;"><div style="display:flex;align-items:center;gap:6px;"><field name="gas_wm_high_note_1000" style="width:90px;" nolabel="1"/><field name="gas_wm_high_note_1000_pct" style="width:52px;color:#6c757d;font-size:0.85em;" nolabel="1" readonly="1"/></div></td>
                                            </tr>
                                            <tr style="border-bottom:1px solid #f0f0f0;">
                                                <td style="padding:6px 10px;font-weight:500;">฿500</td>
                                                <td style="padding:4px 10px;"><div style="display:flex;align-items:center;gap:6px;"><field name="gas_wm_low_note_500" style="width:90px;" nolabel="1"/><field name="gas_wm_low_note_500_pct" style="width:52px;color:#6c757d;font-size:0.85em;" nolabel="1" readonly="1"/></div></td>
                                                <td style="padding:4px 10px;"><div style="display:flex;align-items:center;gap:6px;"><field name="gas_wm_high_note_500" style="width:90px;" nolabel="1"/><field name="gas_wm_high_note_500_pct" style="width:52px;color:#6c757d;font-size:0.85em;" nolabel="1" readonly="1"/></div></td>
                                            </tr>
                                            <tr style="border-bottom:1px solid #f0f0f0;">
                                                <td style="padding:6px 10px;font-weight:500;">฿100</td>
                                                <td style="padding:4px 10px;"><div style="display:flex;align-items:center;gap:6px;"><field name="gas_wm_low_note_100" style="width:90px;" nolabel="1"/><field name="gas_wm_low_note_100_pct" style="width:52px;color:#6c757d;font-size:0.85em;" nolabel="1" readonly="1"/></div></td>
                                                <td style="padding:4px 10px;"><div style="display:flex;align-items:center;gap:6px;"><field name="gas_wm_high_note_100" style="width:90px;" nolabel="1"/><field name="gas_wm_high_note_100_pct" style="width:52px;color:#6c757d;font-size:0.85em;" nolabel="1" readonly="1"/></div></td>
                                            </tr>
                                            <tr style="border-bottom:1px solid #f0f0f0;">
                                                <td style="padding:6px 10px;font-weight:500;">฿50</td>
                                                <td style="padding:4px 10px;"><div style="display:flex;align-items:center;gap:6px;"><field name="gas_wm_low_note_50" style="width:90px;" nolabel="1"/><field name="gas_wm_low_note_50_pct" style="width:52px;color:#6c757d;font-size:0.85em;" nolabel="1" readonly="1"/></div></td>
                                                <td style="padding:4px 10px;"><div style="display:flex;align-items:center;gap:6px;"><field name="gas_wm_high_note_50" style="width:90px;" nolabel="1"/><field name="gas_wm_high_note_50_pct" style="width:52px;color:#6c757d;font-size:0.85em;" nolabel="1" readonly="1"/></div></td>
                                            </tr>
                                            <tr>
                                                <td style="padding:6px 10px;font-weight:500;">฿20</td>
                                                <td style="padding:4px 10px;"><div style="display:flex;align-items:center;gap:6px;"><field name="gas_wm_low_note_20" style="width:90px;" nolabel="1"/><field name="gas_wm_low_note_20_pct" style="width:52px;color:#6c757d;font-size:0.85em;" nolabel="1" readonly="1"/></div></td>
                                                <td style="padding:4px 10px;"><div style="display:flex;align-items:center;gap:6px;"><field name="gas_wm_high_note_20" style="width:90px;" nolabel="1"/><field name="gas_wm_high_note_20_pct" style="width:52px;color:#6c757d;font-size:0.85em;" nolabel="1" readonly="1"/></div></td>
                                            </tr>
                                        </tbody>
                                    </table>

                                    <!-- ── COINS ─────────────────────────────────── -->
                                    <div style="font-weight:600;color:#495057;font-size:0.9em;margin-bottom:6px;padding-bottom:4px;border-bottom:2px solid #dee2e6;">
                                        Coins / เหรียญ
                                    </div>
                                    <table style="width:100%;border-collapse:collapse;table-layout:fixed;">
                                        <colgroup>
                                            <col style="width:18%;"/>
                                            <col style="width:41%;"/>
                                            <col style="width:41%;"/>
                                        </colgroup>
                                        <thead>
                                            <tr style="background:#f8f9fa;font-size:0.82em;color:#6c757d;">
                                                <th style="padding:6px 10px;text-align:left;border-bottom:1px solid #dee2e6;">Denomination</th>
                                                <th style="padding:6px 10px;text-align:left;border-bottom:1px solid #dee2e6;">🔴 Near Empty (Low)</th>
                                                <th style="padding:6px 10px;text-align:left;border-bottom:1px solid #dee2e6;">🟡 Near Full (High)</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr style="border-bottom:1px solid #f0f0f0;">
                                                <td style="padding:6px 10px;font-weight:500;">฿10</td>
                                                <td style="padding:4px 10px;"><div style="display:flex;align-items:center;gap:6px;"><field name="gas_wm_low_coin_10" style="width:90px;" nolabel="1"/><field name="gas_wm_low_coin_10_pct" style="width:52px;color:#6c757d;font-size:0.85em;" nolabel="1" readonly="1"/></div></td>
                                                <td style="padding:4px 10px;"><div style="display:flex;align-items:center;gap:6px;"><field name="gas_wm_high_coin_10" style="width:90px;" nolabel="1"/><field name="gas_wm_high_coin_10_pct" style="width:52px;color:#6c757d;font-size:0.85em;" nolabel="1" readonly="1"/></div></td>
                                            </tr>
                                            <tr style="border-bottom:1px solid #f0f0f0;">
                                                <td style="padding:6px 10px;font-weight:500;">฿5</td>
                                                <td style="padding:4px 10px;"><div style="display:flex;align-items:center;gap:6px;"><field name="gas_wm_low_coin_5" style="width:90px;" nolabel="1"/><field name="gas_wm_low_coin_5_pct" style="width:52px;color:#6c757d;font-size:0.85em;" nolabel="1" readonly="1"/></div></td>
                                                <td style="padding:4px 10px;"><div style="display:flex;align-items:center;gap:6px;"><field name="gas_wm_high_coin_5" style="width:90px;" nolabel="1"/><field name="gas_wm_high_coin_5_pct" style="width:52px;color:#6c757d;font-size:0.85em;" nolabel="1" readonly="1"/></div></td>
                                            </tr>
                                            <tr style="border-bottom:1px solid #f0f0f0;">
                                                <td style="padding:6px 10px;font-weight:500;">฿2</td>
                                                <td style="padding:4px 10px;"><div style="display:flex;align-items:center;gap:6px;"><field name="gas_wm_low_coin_2" style="width:90px;" nolabel="1"/><field name="gas_wm_low_coin_2_pct" style="width:52px;color:#6c757d;font-size:0.85em;" nolabel="1" readonly="1"/></div></td>
                                                <td style="padding:4px 10px;"><div style="display:flex;align-items:center;gap:6px;"><field name="gas_wm_high_coin_2" style="width:90px;" nolabel="1"/><field name="gas_wm_high_coin_2_pct" style="width:52px;color:#6c757d;font-size:0.85em;" nolabel="1" readonly="1"/></div></td>
                                            </tr>
                                            <tr style="border-bottom:1px solid #f0f0f0;">
                                                <td style="padding:6px 10px;font-weight:500;">฿1</td>
                                                <td style="padding:4px 10px;"><div style="display:flex;align-items:center;gap:6px;"><field name="gas_wm_low_coin_1" style="width:90px;" nolabel="1"/><field name="gas_wm_low_coin_1_pct" style="width:52px;color:#6c757d;font-size:0.85em;" nolabel="1" readonly="1"/></div></td>
                                                <td style="padding:4px 10px;"><div style="display:flex;align-items:center;gap:6px;"><field name="gas_wm_high_coin_1" style="width:90px;" nolabel="1"/><field name="gas_wm_high_coin_1_pct" style="width:52px;color:#6c757d;font-size:0.85em;" nolabel="1" readonly="1"/></div></td>
                                            </tr>
                                            <tr style="border-bottom:1px solid #f0f0f0;">
                                                <td style="padding:6px 10px;font-weight:500;">฿0.50</td>
                                                <td style="padding:4px 10px;"><div style="display:flex;align-items:center;gap:6px;"><field name="gas_wm_low_coin_050" style="width:90px;" nolabel="1"/><field name="gas_wm_low_coin_050_pct" style="width:52px;color:#6c757d;font-size:0.85em;" nolabel="1" readonly="1"/></div></td>
                                                <td style="padding:4px 10px;"><div style="display:flex;align-items:center;gap:6px;"><field name="gas_wm_high_coin_050" style="width:90px;" nolabel="1"/><field name="gas_wm_high_coin_050_pct" style="width:52px;color:#6c757d;font-size:0.85em;" nolabel="1" readonly="1"/></div></td>
                                            </tr>
                                            <tr>
                                                <td style="padding:6px 10px;font-weight:500;">฿0.25</td>
                                                <td style="padding:4px 10px;"><div style="display:flex;align-items:center;gap:6px;"><field name="gas_wm_low_coin_025" style="width:90px;" nolabel="1"/><field name="gas_wm_low_coin_025_pct" style="width:52px;color:#6c757d;font-size:0.85em;" nolabel="1" readonly="1"/></div></td>
                                                <td style="padding:4px 10px;"><div style="display:flex;align-items:center;gap:6px;"><field name="gas_wm_high_coin_025" style="width:90px;" nolabel="1"/><field name="gas_wm_high_coin_025_pct" style="width:52px;color:#6c757d;font-size:0.85em;" nolabel="1" readonly="1"/></div></td>
                                            </tr>
                                        </tbody>
                                    </table>

                                </div>
                            </div>

                        </block>

                        <!-- ================================================================ -->
                        <!-- ONLINE / CLOUD SETTINGS                                          -->
                        <!-- ================================================================ -->
                        <block title="Online &amp; Cloud Settings" name="online_settings">

                            <setting string="Company &amp; Branch Info" name="online_company_branch">
                                <div class="content-group">
                                    <div class="row mt16">
                                        <label for="gas_online_owner_code" class="col-lg-3 o_light_label"/>
                                        <field name="gas_online_owner_code" class="col-lg-3"/>
                                        <label for="gas_online_company_code" class="col-lg-3 o_light_label"/>
                                        <field name="gas_online_company_code" class="col-lg-3"/>
                                    </div>
                                    <div class="row mt8">
                                        <label for="gas_online_company_name" class="col-lg-3 o_light_label"/>
                                        <field name="gas_online_company_name" class="col-lg-3"/>
                                        <label for="gas_online_branch_code" class="col-lg-3 o_light_label"/>
                                        <field name="gas_online_branch_code" class="col-lg-3"/>
                                    </div>
                                    <div class="row mt8">
                                        <label for="gas_online_branch_name" class="col-lg-3 o_light_label"/>
                                        <field name="gas_online_branch_name" class="col-lg-3"/>
                                        <label for="gas_online_terminal_code" class="col-lg-3 o_light_label"/>
                                        <field name="gas_online_terminal_code" class="col-lg-3"/>
                                    </div>
                                    <div class="row mt8">
                                        <label for="gas_online_business_types" class="col-lg-3 o_light_label"/>
                                        <field name="gas_online_business_types" class="col-lg-9"
                                            placeholder="gas_station,convenience_store,coffee_shop,rental"/>
                                    </div>
                                </div>
                            </setting>

                            <setting string="Cloud Connection (AWS)" name="online_cloud_connection">
                                <div class="content-group">
                                    <div class="row mt16">
                                        <label for="gas_cloud_enabled" class="col-lg-3 o_light_label"/>
                                        <field name="gas_cloud_enabled" widget="boolean_toggle" class="col-lg-3"/>
                                    </div>
                                    <div class="row mt8" invisible="not gas_cloud_enabled">
                                        <label for="gas_cloud_host" class="col-lg-3 o_light_label"/>
                                        <field name="gas_cloud_host" class="col-lg-9"
                                            placeholder="https://api.example.aws.com"/>
                                    </div>
                                    <div class="row mt8" invisible="not gas_cloud_enabled">
                                        <label for="gas_cloud_port" class="col-lg-3 o_light_label"/>
                                        <field name="gas_cloud_port" class="col-lg-3"/>
                                        <label for="gas_cloud_api_key" class="col-lg-3 o_light_label"/>
                                        <field name="gas_cloud_api_key" class="col-lg-3" password="True"/>
                                    </div>
                                </div>
                            </setting>

                            <setting string="Sync Settings" name="online_sync_settings"
                                invisible="not gas_cloud_enabled">
                                <div class="content-group">
                                    <div class="row mt16">
                                        <label for="gas_cloud_sync_all" class="col-lg-3 o_light_label"/>
                                        <field name="gas_cloud_sync_all" widget="boolean_toggle" class="col-lg-9"/>
                                    </div>
                                    <div class="row">
                                        <div class="col-lg-9 offset-lg-3">
                                            <span class="text-muted" style="font-size:12px;">
                                                Syncs: shift audits, daily reports, deposits, withdrawals, exchanges, cash inventory.
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            </setting>

                        </block>
                    </app>
                </xpath>
            </field>
        </record>

    </data>
</odoo>