<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── List View ───────────────────────────────────────────────── -->
    <record id="view_cash_exchange_list" model="ir.ui.view">
        <field name="name">gas.station.cash.exchange.list</field>
        <field name="model">gas.station.cash.exchange</field>
        <field name="arch" type="xml">
            <tree string="Cash Exchange Audit" default_order="exchange_time desc"
                  create="false" edit="false" delete="true"
                  decoration-danger="machine_status == 'failed'"
                  decoration-success="machine_status == 'ok'">
                <field name="name"/>
                <field name="exchange_time"/>
                <field name="staff_name"/>
                <field name="staff_external_id"/>
                <field name="cashin_amount"/>
                <field name="cashout_amount"/>
                <field name="machine_status"/>
            </tree>
        </field>
    </record>

    <!-- ── Form View ───────────────────────────────────────────────── -->
    <record id="view_cash_exchange_form" model="ir.ui.view">
        <field name="name">gas.station.cash.exchange.form</field>
        <field name="model">gas.station.cash.exchange</field>
        <field name="arch" type="xml">
            <form string="Cash Exchange Audit" create="false" edit="false">
                <header>
                    <button name="%(gas_station_cash.action_report_cash_exchange)d"
                            type="action"
                            string="Print"
                            class="btn-secondary"
                            icon="fa-print"/>
                </header>
                <sheet>
                    <group>
                        <group string="Transaction">
                            <field name="name"/>
                            <field name="exchange_time"/>
                            <field name="machine_status"/>
                        </group>
                        <group string="Staff">
                            <field name="staff_id"/>
                            <field name="staff_external_id"/>
                            <field name="staff_name"/>
                        </group>
                    </group>
                    <group string="Amounts">
                        <group>
                            <field name="cashin_amount"/>
                        </group>
                        <group>
                            <field name="cashout_amount"/>
                        </group>
                    </group>
                    <group string="Cash-In Breakdown">
                        <field name="cashin_breakdown_summary" nolabel="1"/>
                    </group>
                    <group string="Cash-Out Breakdown">
                        <field name="cashout_breakdown_summary" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ── Action ──────────────────────────────────────────────────── -->
    <record id="action_cash_exchange_audit" model="ir.actions.act_window">
        <field name="name">Cash Exchange Audit</field>
        <field name="res_model">gas.station.cash.exchange</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'create': False}</field>
    </record>

    <!-- ── Menu ────────────────────────────────────────────────────── -->
    <menuitem
        id="menu_cash_exchange_audit"
        name="Cash Exchange"
        parent="menu_gas_station_cash_root"
        action="action_cash_exchange_audit"
        sequence="25"/>

    <data noupdate="1">
        <record id="seq_cash_exchange" model="ir.sequence">
            <field name="name">Cash Exchange</field>
            <field name="code">gas.station.cash.exchange</field>
            <field name="prefix">EXC-</field>
            <field name="padding">5</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>
    </data>

</odoo>