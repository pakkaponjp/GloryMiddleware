<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ── Sequence ────────────────────────────────────────────────── -->
        <record id="seq_gas_station_cash_replenish" model="ir.sequence">
            <field name="name">Cash Replenish</field>
            <field name="code">gas.station.cash.replenish</field>
            <field name="prefix">RPL</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- ── List View ────────────────────────────────────────────────── -->
        <record id="view_cash_replenish_list" model="ir.ui.view">
            <field name="name">gas.station.cash.replenish.list</field>
            <field name="model">gas.station.cash.replenish</field>
            <field name="arch" type="xml">
                <tree string="Cash Replenish" default_order="replenish_date desc">
                    <field name="name"/>
                    <field name="replenish_date"/>
                    <field name="staff_id"/>
                    <field name="mode"/>
                    <field name="total_amount" sum="Total"/>
                    <field name="state"/>
                    <field name="audit_shift_number" optional="show"/>
                </tree>
            </field>
        </record>

        <!-- ── Form View ────────────────────────────────────────────────── -->
        <record id="view_cash_replenish_form" model="ir.ui.view">
            <field name="name">gas.station.cash.replenish.form</field>
            <field name="model">gas.station.cash.replenish</field>
            <field name="arch" type="xml">
                <form string="Cash Replenish">
                    <header>
                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="name" readonly="1"/></h1>
                        </div>
                        <group>
                            <group>
                                <field name="replenish_date"/>
                                <field name="staff_id"/>
                                <field name="mode"/>
                            </group>
                            <group>
                                <field name="total_amount" readonly="1"/>
                                <field name="audit_id" readonly="1"/>
                                <field name="audit_shift_number" readonly="1"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Denomination Breakdown">
                                <field name="replenish_line_ids" readonly="1">
                                    <tree>
                                        <field name="currency_denomination"/>
                                        <field name="quantity"/>
                                        <field name="subtotal" sum="Total"/>
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                        <field name="notes"/>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- ── Action ───────────────────────────────────────────────────── -->
        <record id="action_cash_replenish" model="ir.actions.act_window">
            <field name="name">Cash Replenish</field>
            <field name="res_model">gas.station.cash.replenish</field>
            <field name="view_mode">list,form</field>
            <field name="context">{}</field>
        </record>

        <!-- ── Menu (under Cash Operations) ────────────────────────────── -->
        <menuitem
            id="menu_cash_replenish"
            name="Cash Replenish"
            parent="gas_station_cash.menu_gas_station_cash_root"
            action="action_cash_replenish"
            sequence="45"/>

    </data>
</odoo>