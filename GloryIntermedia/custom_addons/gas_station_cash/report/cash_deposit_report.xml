<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_cash_deposit" model="ir.actions.report">
        <field name="name">ใบฝากเงินสด</field>
        <field name="model">gas.station.cash.deposit</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">gas_station_cash.report_cash_deposit</field>
        <field name="report_file">gas_station_cash.report_cash_deposit</field>
        <field name="binding_model_id" ref="model_gas_station_cash_deposit"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="base.paperformat_euro"/>
        <field name="print_report_name">'ใบฝากเงินสด_' + (object.date.strftime('%d%m%Y_%H%M') if object.date else object.name)</field>
    </record>

    <template id="report_cash_deposit">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <style>
                        body, table, th, td, p, span, h1, h2, h3, h4, h5 {
                            font-family: 'TH Sarabun New', 'Garuda', 'Noto Sans Thai', 'FreeSans', sans-serif !important;
                        }
                        .sec { background:#f8f9fa; font-weight:bold; font-size:10px;
                               text-transform:uppercase; letter-spacing:0.5px;
                               padding:3px 6px; border-top:1.5px solid #dee2e6;
                               border-bottom:1px solid #dee2e6; margin-top:10px; margin-bottom:3px; }
                        table.info td { padding:1px 4px; font-size:12px; }
                        table.info td:first-child { color:#6c757d; min-width:150px; }
                        .badge-ok   { background:#198754; color:#fff; border-radius:4px; padding:1px 6px; font-size:10px; }
                        .badge-err  { background:#dc3545; color:#fff; border-radius:4px; padding:1px 6px; font-size:10px; }
                        .badge-warn { background:#ffc107; color:#000; border-radius:4px; padding:1px 6px; font-size:10px; }
                        .badge-inf  { background:#0d6efd; color:#fff; border-radius:4px; padding:1px 6px; font-size:10px; }
                        .badge-sec  { background:#6c757d; color:#fff; border-radius:4px; padding:1px 6px; font-size:10px; }
                    </style>
                    <div class="page" style="font-size:12px;">

                        <!-- HEADER -->
                        <div class="row mb-2">
                            <div class="col-8">
                                <h4 style="margin-bottom:2px;">ฝากเงินสด (Cash Deposit)</h4>
                                <span class="text-muted" style="font-size:11px;" t-esc="doc.name"/>
                            </div>
                            <div class="col-4 text-end">
                                <span t-attf-class="#{'badge-ok' if doc.state == 'audited' else 'badge-inf' if doc.state == 'confirmed' else 'badge-sec'}">
                                    <t t-esc="{'draft':'ร่าง','confirmed':'ยืนยันแล้ว','audited':'ตรวจสอบแล้ว'}.get(doc.state, doc.state)"/>
                                </span>
                                <t t-if="doc.is_pos_related">
                                    <br/>
                                    <span t-attf-class="mt-1 #{'badge-ok' if doc.pos_status == 'ok' else 'badge-warn' if doc.pos_status == 'queued' else 'badge-err' if doc.pos_status == 'failed' else 'badge-inf' if doc.pos_status == 'offline' else 'badge-sec'}">
                                        POS: <t t-esc="{'na':'N/A','ok':'OK','queued':'รอ','failed':'ล้มเหลว','offline':'ออฟไลน์'}.get(doc.pos_status, doc.pos_status)"/>
                                    </span>
                                </t>
                            </div>
                        </div>

                        <!-- Basic Info -->
                        <div class="row mb-2">
                            <div class="col-6">
                                <div class="sec">ข้อมูลพื้นฐาน</div>
                                <table class="info">
                                    <tr><td>พนักงาน</td><td t-esc="doc.staff_id.name if doc.staff_id else '-'"/></tr>
                                    <tr><td>วันที่</td><td t-esc="doc.date.strftime('%d/%m/%Y %H:%M') if doc.date else '-'"/></tr>
                                    <tr><td>บริษัท</td><td t-esc="doc.company_id.name or '-'"/></tr>
                                </table>
                            </div>
                            <div class="col-6">
                                <div class="sec">ประเภทการฝาก</div>
                                <table class="info">
                                    <tr><td>ประเภท</td><td t-esc="{'oil':'ยอดขายน้ำมัน','engine_oil':'น้ำมันเครื่อง','rental':'ค่าเช่า','coffee_shop':'ร้านกาแฟ','convenient_store':'ร้านสะดวกซื้อ','deposit_cash':'เติมเงินสด','exchange_cash':'แลกเงิน'}.get(doc.deposit_type, doc.deposit_type or '-')"/></tr>
                                    <tr><td>สินค้า</td><td t-esc="doc.product_id.name if doc.product_id else '-'"/></tr>
                                    <tr><td>เชื่อมกับ POS</td><td t-esc="'ใช่' if doc.is_pos_related else 'ไม่'"/></tr>
                                    <tr><td>สรุปกะ</td><td t-esc="doc.audit_id.name if doc.audit_id else '-'"/></tr>
                                    <tr><td>ออฟไลน์</td><td t-esc="'ใช่' if doc.is_offline else 'ไม่'"/></tr>
                                </table>
                            </div>
                        </div>

                        <!-- ═══ TAB 1: DEPOSIT LINES ══════════════════════ -->
                        <t t-if="doc.deposit_line_ids">
                            <div class="sec">รายละเอียดธนบัตร/เหรียญ</div>
                            <table class="table table-sm table-bordered" style="font-size:12px;">
                                <thead style="background-color:#343a40; color:#fff;">
                                    <tr>
                                        <th>ชนิด (บาท)</th>
                                        <th class="text-center">จำนวน</th>
                                        <th class="text-end">ยอดรวม (บาท)</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="doc.deposit_line_ids" t-as="line">
                                        <tr>
                                            <td t-esc="'฿{:,.2f}'.format(line.currency_denomination)"/>
                                            <td class="text-center" t-esc="line.quantity"/>
                                            <td class="text-end" t-esc="'฿{:,.2f}'.format(line.subtotal)"/>
                                        </tr>
                                    </t>
                                </tbody>
                                <tfoot>
                                    <tr style="font-weight:bold;">
                                        <td colspan="2" class="text-end">ยอดรวม</td>
                                        <td class="text-end" t-esc="'฿{:,.2f}'.format(doc.total_amount)"/>
                                    </tr>
                                </tfoot>
                            </table>
                        </t>

                        <!-- ═══ TAB 2: POS AUDIT ══════════════════════════ -->
                        <t t-if="doc.is_pos_related">
                            <div class="sec">ข้อมูล POS</div>
                            <div class="row">
                                <div class="col-6">
                                    <table class="info">
                                        <tr><td>POS Transaction ID</td><td t-esc="doc.pos_transaction_id or '-'"/></tr>
                                        <tr><td>สถานะ POS</td>
                                            <td>
                                                <span t-attf-class="#{'badge-ok' if doc.pos_status == 'ok' else 'badge-warn' if doc.pos_status == 'queued' else 'badge-err' if doc.pos_status == 'failed' else 'badge-inf' if doc.pos_status == 'offline' else 'badge-sec'}">
                                                    <t t-esc="{'na':'N/A','ok':'OK','queued':'รอ','failed':'ล้มเหลว','offline':'ออฟไลน์'}.get(doc.pos_status, doc.pos_status)"/>
                                                </span>
                                            </td>
                                        </tr>
                                        <tr><td>POS Timestamp</td><td t-esc="doc.pos_time_stamp or '-'"/></tr>
                                    </table>
                                </div>
                                <div class="col-6">
                                    <table class="info">
                                        <tr><td>คำอธิบาย POS</td><td t-esc="doc.pos_description or '-'"/></tr>
                                        <tr><td>ข้อผิดพลาด</td><td t-esc="doc.pos_error or '-'"/></tr>
                                    </table>
                                </div>
                            </div>
                            <t t-if="doc.pos_response_json">
                                <p class="fw-bold mb-1 mt-2" style="font-size:11px;">Raw Response JSON:</p>
                                <pre style="font-size:10px; background:#f8f9fa; padding:6px; border-radius:4px; white-space:pre-wrap; word-break:break-all;" t-esc="doc.pos_response_json"/>
                            </t>
                        </t>

                        <!-- ═══ TAB 3: NOTES ══════════════════════════════ -->
                        <t t-if="doc.notes">
                            <div class="sec">หมายเหตุ</div>
                            <p style="font-size:11px; margin:4px 0; white-space:pre-wrap;" t-esc="doc.notes"/>
                        </t>

                        <!-- Total + Signatures -->
                        <div class="row mt-3">
                            <div class="col-12 text-end">
                                <strong style="font-size:13px;">ยอดรวมทั้งสิ้น: <t t-esc="'฿{:,.2f}'.format(doc.total_amount)"/> บาท</strong>
                            </div>
                        </div>

                        <div class="row mt-4" style="font-size:11px;">
                            <div class="col-4 text-center">
                                <div style="border-top:1px solid #000; margin-top:30px; padding-top:4px;">ผู้ฝาก</div>
                            </div>
                            <div class="col-4 text-center">
                                <div style="border-top:1px solid #000; margin-top:30px; padding-top:4px;">ผู้ตรวจสอบ</div>
                            </div>
                            <div class="col-4 text-center">
                                <div style="border-top:1px solid #000; margin-top:30px; padding-top:4px;">ผู้อนุมัติ</div>
                            </div>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>