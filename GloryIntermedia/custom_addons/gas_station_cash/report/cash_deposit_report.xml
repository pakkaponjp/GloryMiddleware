<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ══════════════════════════════════════════════════════════
         Report Action — triggers the PDF from form view button
    ══════════════════════════════════════════════════════════ -->
    <record id="action_report_cash_deposit" model="ir.actions.report">
        <field name="name">Cash Deposit</field>
        <field name="model">gas.station.cash.deposit</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">gas_station_cash.report_cash_deposit</field>
        <field name="report_file">gas_station_cash.report_cash_deposit</field>
        <field name="binding_model_id" ref="model_gas_station_cash_deposit"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="base.paperformat_euro"/>
    </record>

    <!-- ══════════════════════════════════════════════════════════
         QWeb Template
    ══════════════════════════════════════════════════════════ -->
    <template id="report_cash_deposit">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">

                        <!-- ── Header ───────────────────────────── -->
                        <div class="row mb-4">
                            <div class="col-6">
                                <h2>Cash Deposit</h2>
                                <h3 class="text-muted" t-esc="doc.name"/>
                            </div>
                            <div class="col-6 text-end">
                                <!-- Status badge -->
                                <span t-attf-class="badge #{
                                    'bg-secondary' if doc.state == 'draft' else
                                    'bg-primary'   if doc.state == 'confirmed' else
                                    'bg-success'
                                }" style="font-size:14px;">
                                    <t t-esc="dict(doc._fields['state'].selection).get(doc.state)"/>
                                </span>
                                <t t-if="doc.is_pos_related">
                                    <br/>
                                    <span t-attf-class="badge mt-1 #{
                                        'bg-success'  if doc.pos_status == 'ok'     else
                                        'bg-warning'  if doc.pos_status == 'queued' else
                                        'bg-danger'   if doc.pos_status == 'failed' else
                                        'bg-secondary'
                                    }">
                                        POS: <t t-esc="dict(doc._fields['pos_status'].selection).get(doc.pos_status)"/>
                                    </span>
                                </t>
                            </div>
                        </div>

                        <!-- ── Basic Info ────────────────────────── -->
                        <div class="row mb-4">
                            <div class="col-6">
                                <table class="table table-sm table-borderless">
                                    <tr>
                                        <td class="fw-bold" style="width:140px;">Staff</td>
                                        <td t-esc="doc.staff_id.name or '-'"/>
                                    </tr>
                                    <tr>
                                        <td class="fw-bold">Date</td>
                                        <td t-esc="doc.date.strftime('%d/%m/%Y %H:%M') if doc.date else '-'"/>
                                    </tr>
                                    <tr>
                                        <td class="fw-bold">Company</td>
                                        <td t-esc="doc.company_id.name or '-'"/>
                                    </tr>
                                </table>
                            </div>
                            <div class="col-6">
                                <table class="table table-sm table-borderless">
                                    <tr>
                                        <td class="fw-bold" style="width:140px;">Deposit Type</td>
                                        <td t-esc="dict(doc._fields['deposit_type'].selection).get(doc.deposit_type) or '-'"/>
                                    </tr>
                                    <tr>
                                        <td class="fw-bold">Product</td>
                                        <td t-esc="doc.product_id.name or '-'"/>
                                    </tr>
                                    <tr>
                                        <td class="fw-bold">Shift Audit</td>
                                        <td t-esc="doc.audit_id.name or '-'"/>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <!-- ── Deposit Lines ─────────────────────── -->
                        <t t-if="doc.deposit_line_ids">
                            <h5 class="mt-2 mb-2 border-bottom pb-1">Deposit Lines</h5>
                            <table class="table table-sm table-bordered">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Denomination (THB)</th>
                                        <th class="text-center">Quantity</th>
                                        <th class="text-end">Subtotal (THB)</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="doc.deposit_line_ids" t-as="line">
                                        <tr>
                                            <td t-esc="'฿{:,.2f}'.format(line.currency_denomination)"/>
                                            <td class="text-center" t-esc="line.quantity"/>
                                            <td class="text-end" t-esc="'฿{:,.2f}'.format(line.subtotal)"/>
                                        </tr>
                                    </t>
                                </tbody>
                                <tfoot>
                                    <tr class="fw-bold">
                                        <td colspan="2" class="text-end">Total</td>
                                        <td class="text-end"
                                            t-esc="'฿{:,.2f}'.format(doc.total_amount)"/>
                                    </tr>
                                </tfoot>
                            </table>
                        </t>

                        <!-- ── POS Audit (only if POS related) ───── -->
                        <t t-if="doc.is_pos_related">
                            <h5 class="mt-4 mb-2 border-bottom pb-1">POS Audit</h5>
                            <div class="row">
                                <div class="col-6">
                                    <table class="table table-sm table-borderless">
                                        <tr>
                                            <td class="fw-bold" style="width:160px;">Transaction ID</td>
                                            <td t-esc="doc.pos_transaction_id or '-'"/>
                                        </tr>
                                        <tr>
                                            <td class="fw-bold">POS Status</td>
                                            <td t-esc="dict(doc._fields['pos_status'].selection).get(doc.pos_status) or '-'"/>
                                        </tr>
                                        <tr>
                                            <td class="fw-bold">POS Timestamp</td>
                                            <td t-esc="doc.pos_time_stamp or '-'"/>
                                        </tr>
                                    </table>
                                </div>
                                <div class="col-6">
                                    <table class="table table-sm table-borderless">
                                        <tr>
                                            <td class="fw-bold" style="width:160px;">Description</td>
                                            <td t-esc="doc.pos_description or '-'"/>
                                        </tr>
                                        <tr>
                                            <td class="fw-bold">Error / Reason</td>
                                            <td t-esc="doc.pos_error or '-'"/>
                                        </tr>
                                    </table>
                                </div>
                            </div>
                            <t t-if="doc.pos_response_json">
                                <div class="mt-2">
                                    <span class="fw-bold">Raw Response JSON:</span>
                                    <pre style="font-size:10px; background:#f8f9fa;
                                                padding:8px; border-radius:4px;
                                                white-space:pre-wrap; word-break:break-all;"
                                         t-esc="doc.pos_response_json"/>
                                </div>
                            </t>
                        </t>

                        <!-- ── Notes ────────────────────────────── -->
                        <t t-if="doc.notes">
                            <h5 class="mt-4 mb-2 border-bottom pb-1">Notes</h5>
                            <p t-esc="doc.notes" style="white-space:pre-wrap;"/>
                        </t>

                        <!-- ── Footer total highlight ────────────── -->
                        <div class="row mt-4">
                            <div class="col-12 text-end">
                                <div style="display:inline-block; border:2px solid #343a40;
                                            border-radius:6px; padding:8px 24px;">
                                    <span class="fw-bold" style="font-size:16px;">
                                        Total Amount:
                                        <t t-esc="'฿{:,.2f}'.format(doc.total_amount)"/>
                                    </span>
                                </div>
                            </div>
                        </div>

                    </div><!-- /page -->
                </t><!-- /external_layout -->
            </t><!-- /foreach -->
        </t><!-- /html_container -->
    </template>
</odoo>