<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

  <t t-name="gas_station_cash.DepositWithAmountScreen">
    <div class="deposit-with-amount-screen">
      <div class="dwa-card">

        <!-- ── Header ────────────────────────────────────────────────────── -->
        <div class="dwa-header">
          <div class="dwa-icon"><i class="fa fa-exchange"/></div>
          <div class="dwa-title" t-esc="depositTypeName"/>
          <div class="dwa-subtitle">Deposit with Amount</div>
        </div>

        <!-- ── Skip (coffee_shop / convenient_store only) ────────────────── -->
        <div t-if="showSkipButton" class="dwa-skip-row">
          <button class="dwa-btn-skip"
            t-on-click="() => this._onSkipToNormal()"
            t-att-disabled="state.busy">
            Deposit Without Amount →
          </button>
        </div>

        <!-- ── Amount Display ─────────────────────────────────────────────── -->
        <div class="dwa-amount-display">
          <span class="dwa-currency">฿</span>
          <span class="dwa-amount" t-esc="displayAmount"/>
        </div>

        <!-- ── Error ──────────────────────────────────────────────────────── -->
        <div t-if="state.error" class="dwa-error" t-esc="state.error"/>

        <!-- ── Processing ─────────────────────────────────────────────────── -->
        <div t-if="state.step === 'processing'" class="dwa-processing">
          <div class="dwa-spinner"/>
          <div class="dwa-processing-text">Please insert cash into the machine...</div>
          <div class="dwa-processing-sub">Machine will dispense change automatically</div>
        </div>

        <!-- ── Done ───────────────────────────────────────────────────────── -->
        <div t-if="state.step === 'done'" class="dwa-done">
          <div class="dwa-done-icon">✓</div>
          <div class="dwa-done-text" t-esc="state.resultMessage"/>

          <!-- Summary table -->
          <div class="dwa-summary-table">
            <div class="dwa-summary-row">
              <span class="dwa-summary-label">Cash Inserted</span>
              <span class="dwa-summary-value"
                t-esc="'฿' + (state.insertedSatang / 100).toLocaleString('th-TH', {minimumFractionDigits:2})"/>
            </div>
            <div class="dwa-summary-row">
              <span class="dwa-summary-label">Deposit Amount</span>
              <span class="dwa-summary-value dwa-summary-deposit"
                t-esc="'฿' + (numericAmountSatang / 100).toLocaleString('th-TH', {minimumFractionDigits:2})"/>
            </div>
            <div class="dwa-summary-row dwa-summary-divider">
              <span class="dwa-summary-label">Change</span>
              <span class="dwa-summary-value dwa-summary-change"
                t-esc="'฿' + (state.changeSatang / 100).toLocaleString('th-TH', {minimumFractionDigits:2})"/>
            </div>
          </div>

          <div class="dwa-done-sub">Returning to menu...</div>
        </div>

        <!-- ── Number Pad (amount step only) ─────────────────────────────── -->
        <t t-if="state.step === 'amount'">
          <div class="dwa-numpad">
            <t t-foreach="[1,2,3,4,5,6,7,8,9]" t-as="n" t-key="n">
              <button class="dwa-key"
                t-on-click="() => this._onKeypadPress(n)"
                t-att-disabled="state.busy">
                <t t-esc="n"/>
              </button>
            </t>
            <button class="dwa-key dwa-key-clear"
              t-on-click="() => this._onClear()"
              t-att-disabled="state.busy">C</button>
            <button class="dwa-key"
              t-on-click="() => this._onKeypadPress(0)"
              t-att-disabled="state.busy">0</button>
            <button class="dwa-key dwa-key-back"
              t-on-click="() => this._onBackspace()"
              t-att-disabled="state.busy">←</button>
          </div>

          <!-- Sub-baht row -->
          <div class="dwa-subbaht-row">
            <button
              t-att-class="state.subBahtSatang === 25 ? 'dwa-key-sub active' : 'dwa-key-sub'"
              t-on-click="() => this._onSubBahtPress(25)"
              t-att-disabled="state.busy">.25</button>
            <button
              t-att-class="state.subBahtSatang === 50 ? 'dwa-key-sub active' : 'dwa-key-sub'"
              t-on-click="() => this._onSubBahtPress(50)"
              t-att-disabled="state.busy">.50</button>
            <button
              t-att-class="state.subBahtSatang === 75 ? 'dwa-key-sub active' : 'dwa-key-sub'"
              t-on-click="() => this._onSubBahtPress(75)"
              t-att-disabled="state.busy">.75</button>
          </div>

          <!-- Action Buttons -->
          <div class="dwa-actions">
            <button class="dwa-btn dwa-btn-cancel"
              t-on-click="() => this._onCancel()">
              ✕ Cancel
            </button>
            <button class="dwa-btn dwa-btn-ok"
              t-on-click="() => this._onConfirm()"
              t-att-disabled="!canConfirm">
              → OK
            </button>
          </div>
        </t>

      </div>
    </div>
  </t>

</templates>