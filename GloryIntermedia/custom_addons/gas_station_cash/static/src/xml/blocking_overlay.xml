<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve" xmlns:t="http://odoo.com/owl">
    <t t-name="gas_station_cash.BlockingOverlay" owl="1">
        <div t-att-class="'gsc_overlay ' + (state.visible ? 'gsc_visible' : 'gsc_hidden')">

            <!-- ========== PROCESSING STATE ========== -->
            <t t-if="showProcessing">
                <div class="gsc_card gsc_processing">
                    <div class="gsc_spinner">⏳</div>
                    <h2 style="color:#ffffff;"><t t-esc="actionText"/></h2>
                    <p style="color:#dddddd;"><t t-esc="messageText"/></p>
                </div>
            </t>

            <!-- ========== ERROR STATE ========== -->
            <t t-if="showError">
                <div class="gsc_card gsc_error_card">
                    <div class="gsc_error_icon">⚠️</div>
                    <h2 style="color:#ffffff;"><t t-esc="actionText"/></h2>
                    <p class="gsc_error_message" style="color:#ffcccc;"><t t-esc="messageText"/></p>
                    <t t-if="subMessageText">
                        <p class="gsc_error_sub" style="color:#dddddd;"><t t-esc="subMessageText"/></p>
                    </t>
                    <t t-if="state.showCloseButton">
                        <button class="gsc_btn gsc_btn_close" t-on-click="onCloseError">Close</button>
                    </t>
                </div>
            </t>

            <!-- ========== INSUFFICIENT RESERVE STATE ========== -->
            <t t-if="showInsufficientReserve">
                <div class="gsc_card gsc_insufficient_reserve">
                    <div class="gsc_warning_icon">⚠️</div>
                    <h2 style="color:#ffffff;">Insufficient Reserve</h2>
                    <p style="color:#ffccaa;">Cash in machine is below required reserve amount.</p>

                    <div class="gsc_reserve_info">
                        <div class="gsc_reserve_row">
                            <span class="gsc_reserve_label" style="color:#dddddd;">Current Cash:</span>
                            <span class="gsc_reserve_value" style="color:#ffffff;">฿<t t-esc="currentCashFormatted"/></span>
                        </div>
                        <div class="gsc_reserve_row">
                            <span class="gsc_reserve_label" style="color:#dddddd;">Required Reserve:</span>
                            <span class="gsc_reserve_value" style="color:#ffffff;">฿<t t-esc="requiredReserveFormatted"/></span>
                        </div>
                        <div class="gsc_reserve_row gsc_shortfall">
                            <span class="gsc_reserve_label" style="color:#ffaaaa;">Shortfall:</span>
                            <span class="gsc_reserve_value" style="color:#ffaaaa;">฿<t t-esc="shortfallFormatted"/></span>
                        </div>
                    </div>

                    <p style="color:#aaaaaa; font-size:0.85rem;">No cash was collected to Collection Box.</p>

                    <button class="gsc_btn gsc_btn_close" t-on-click="onCloseInsufficientReserve">Acknowledge</button>
                </div>
            </t>

            <!-- ========== POS DISCONNECTED / OFFLINE MODE ========== -->
            <t t-if="showPosDisconnected">
                <div class="gsc_card gsc_pos_disconnected">
                    <div class="gsc_warning_icon" style="font-size:3rem;">📡</div>
                    <h2 style="color:#ffffff; margin:0.5rem 0;">POS Connection Lost</h2>
                    <p style="color:#ffccaa; margin:0 0 0.5rem;">
                        POS system is not responding.
                    </p>
                    <p style="color:#dddddd; font-size:0.9rem; margin:0 0 1.5rem;">
                        You can operate in offline mode. All cash operations will continue normally.<br/>
                        Oil deposits will not be sent to POS until reconnected.
                    </p>
                    <div class="gsc_offline_actions">
                        <button class="gsc_btn gsc_btn_offline" t-on-click="onActivateOfflineMode">
                            ⚡ Operate Offline
                        </button>
                        <button class="gsc_btn gsc_btn_wait" t-on-click="onWaitForReconnection">
                            ⏳ Wait for Reconnection
                        </button>
                    </div>
                </div>
            </t>

            <!-- ========== END-OF-DAY COLLECTION SUMMARY ========== -->
            <t t-if="showCollectionSummary">
                <div class="gsc_card gsc_collection_summary">
                    <div style="font-size:2.5rem; margin-bottom:0.5rem;">✅</div>
                    <h2 style="color:#ffffff; font-size:1.5rem; margin:0 0 0.3rem;">End of Day Complete</h2>
                    <p style="color:#c8f7c5; font-size:0.95rem; margin:0 0 1.5rem;">Cash has been moved to collection box.</p>
                    <p style="color:#aaaaaa; font-size:0.85rem; margin-top:0.5rem;">Closing automatically in 3 seconds...</p>
                </div>
            </t>

        </div>
    </t>
</templates>