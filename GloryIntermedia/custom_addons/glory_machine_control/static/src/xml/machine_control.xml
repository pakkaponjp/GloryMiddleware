<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve" xmlns:t="http://odoo.com/owl">
    <t t-name="glory_machine_control.MachineControl">
        <div class="mc-root">

            <!-- HEADER -->
            <div class="mc-header">
                <div class="mc-header-left">
                    <div class="mc-logo-wrap">
                        <svg width="22" height="22" viewBox="0 0 28 28" fill="none">
                            <polygon points="14,2 26,8 26,20 14,26 2,20 2,8" fill="#1a56db" opacity="0.15"/>
                            <polygon points="14,2 26,8 26,20 14,26 2,20 2,8" fill="none" stroke="#1a56db" stroke-width="2"/>
                            <circle cx="14" cy="14" r="4" fill="#1a56db"/>
                        </svg>
                    </div>
                    <div>
                        <h1 class="mc-title">Glory Machine</h1>
                        <span class="mc-subtitle">Cash Recycler Control Panel</span>
                    </div>
                </div>

            </div>

            <!-- BODY -->
            <div class="mc-body">


                <!-- ROW 1: Wizard + Actions -->
                <div class="mc-row-main">

                    <!-- Cassette Replacement Wizard -->
                    <div class="mc-card mc-card-wizard">
                        <div class="mc-card-header-row">
                            <div class="mc-unit-icon mc-icon-purple">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M12 2L2 7l10 5 10-5-10-5z"/>
                                    <path d="M2 17l10 5 10-5M2 12l10 5 10-5"/>
                                </svg>
                            </div>
                            <div>
                                <span class="mc-card-title">Cassette Replacement</span>
                                <span class="mc-card-hint">Collection box swap — follow steps in order</span>
                            </div>
                        </div>

                        <!-- Horizontal Timeline -->
                        <div class="mc-htl">

                            <!-- Step track (dots + lines) -->
                            <div class="mc-htl-track">
                                <div t-att-class="'mc-htl-dot' + (state.wizardPhase === 0 ? ' htl-current' : '') + (state.wizardPhase > 0 ? ' htl-done' : '')">
                                    <t t-if="state.wizardPhase > 0"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M5 12l5 5L19 7"/></svg></t>
                                    <t t-else="">1</t>
                                </div>
                                <div t-att-class="'mc-htl-line' + (state.wizardPhase > 0 ? ' htl-done' : '')"/>
                                <div t-att-class="'mc-htl-dot' + (state.wizardPhase === 1 ? ' htl-current' : '') + (state.wizardPhase > 1 ? ' htl-done' : '') + (state.wizardPhase &lt; 1 ? ' htl-pending' : '')">
                                    <t t-if="state.wizardPhase > 1"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M5 12l5 5L19 7"/></svg></t>
                                    <t t-else="">2</t>
                                </div>
                                <div t-att-class="'mc-htl-line' + (state.wizardPhase > 1 ? ' htl-done' : '')"/>
                                <div t-att-class="'mc-htl-dot' + (state.wizardPhase === 2 ? ' htl-current' : '') + (state.wizardPhase >= 4 ? ' htl-done' : '') + (state.wizardPhase &lt; 2 ? ' htl-pending' : '')">
                                    <t t-if="state.wizardPhase >= 4"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M5 12l5 5L19 7"/></svg></t>
                                    <t t-else="">3</t>
                                </div>
                            </div>

                            <!-- Step labels -->
                            <div class="mc-htl-labels">
                                <span t-att-class="'mc-htl-label' + (state.wizardPhase === 0 ? ' htl-current' : '') + (state.wizardPhase > 0 ? ' htl-done' : '')">Unlock Coin</span>
                                <span t-att-class="'mc-htl-label' + (state.wizardPhase === 1 ? ' htl-current' : '') + (state.wizardPhase > 1 ? ' htl-done' : '') + (state.wizardPhase &lt; 1 ? ' htl-pending' : '')">Lock Coin</span>
                                <span t-att-class="'mc-htl-label' + (state.wizardPhase === 2 ? ' htl-current' : '') + (state.wizardPhase >= 4 ? ' htl-done' : '') + (state.wizardPhase &lt; 2 ? ' htl-pending' : '')">Lock Note</span>
                            </div>

                            <!-- Active step action area -->
                            <div class="mc-htl-action">
                                <!-- Phase 0: start -->
                                <t t-if="state.wizardPhase === 0">
                                    <span class="mc-htl-instruction">Press to eject and unlock the coin cassette</span>
                                    <button class="mc-tl-btn mc-tl-btn-blue" t-on-click="wizardStartUnlockAll" t-att-disabled="state.loading">
                                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 9.9-1"/></svg>
                                        Unlock Coin
                                    </button>
                                </t>
                                <!-- Phase 1: replace notes -->
                                <t t-if="state.wizardPhase === 1">
                                    <div class="mc-tl-alert">
                                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
                                        Insert empty note cassette, then press Lock Note
                                    </div>
                                    <button class="mc-tl-btn mc-tl-btn-amber" t-on-click="wizardLockCoinsAndUnlockNotes" t-att-disabled="state.loading">
                                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                                        Lock Coin
                                    </button>
                                </t>
                                <!-- Phase 2: replace coins -->
                                <t t-if="state.wizardPhase === 2">
                                    <div class="mc-tl-alert">
                                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
                                        Insert empty note cassette, then press Lock Note
                                    </div>
                                    <button class="mc-tl-btn mc-tl-btn-amber" t-on-click="wizardLockNotesFinish" t-att-disabled="state.loading">
                                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                                        Lock Note
                                    </button>
                                </t>
                                <!-- Phase 4: complete -->
                                <t t-if="state.wizardPhase === 4">
                                    <div class="mc-tl-complete">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><path d="M8 12l3 3 5-5"/></svg>
                                        <span>Complete — machine is ready</span>
                                        <button class="mc-btn mc-btn-slate mc-btn-xs" t-on-click="wizardPhaseReset">Reset</button>
                                    </div>
                                </t>
                            </div>

                        </div>
                    </div>

                    <!-- Action buttons column -->
                    <div class="mc-col-actions">

                        <!-- Collect Cash (2 sections) -->
                        <div class="mc-action-card mc-action-blue mc-collect-card">

                            <!-- Section 1: Collect Cash (from setting) -->
                            <div t-att-class="'mc-collect-section mc-collect-top' + (state.leaveFloat ? '' : ' mc-section-disabled')">
                                <div class="mc-action-icon">
                                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                        <rect x="2" y="4" width="20" height="15" rx="2"/>
                                        <circle cx="12" cy="11" r="3"/>
                                        <path d="M12 8v1M12 13v1M9 11H8M16 11h-1M7 19v2M17 19v2"/>
                                    </svg>
                                </div>
                                <div class="mc-action-text">
                                    <span class="mc-action-title">Collect Cash</span>
                                    <span class="mc-action-desc">Collect by setting amount</span>
                                </div>
                                <button class="mc-action-btn" t-on-click="collectCash"
                                    t-att-disabled="state.loading || !state.leaveFloat">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
                                </button>
                            </div>

                            <div class="mc-collect-divider"/>

                            <!-- Section 2: Collect All Cash -->
                            <div t-att-class="'mc-collect-section mc-collect-bottom' + (!state.leaveFloat ? '' : ' mc-section-disabled')">
                                <div class="mc-action-icon">
                                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                        <rect x="2" y="4" width="20" height="15" rx="2"/>
                                        <circle cx="12" cy="11" r="3"/>
                                        <path d="M12 8v1M12 13v1M9 11H8M16 11h-1M7 19v2M17 19v2"/>
                                    </svg>
                                </div>
                                <div class="mc-action-text">
                                    <span class="mc-action-title">Collect All Cash</span>
                                    <span class="mc-action-desc">Transfer all to collection box</span>
                                </div>
                                <button class="mc-action-btn" t-on-click="allCollect"
                                    t-att-disabled="state.loading || state.leaveFloat">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
                                </button>
                            </div>

                        </div>

                        <!-- Coins Unit -->
                            <div class="mc-unit-strip">
                                <div class="mc-unit-icon mc-icon-amber">
                                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                        <circle cx="12" cy="12" r="9"/>
                                        <path d="M12 7v10M9.5 9.5c0-1.4 1.1-2.5 2.5-2.5s2.5 1.1 2.5 2.5-1.1 2.5-2.5 2.5-2.5 1.1-2.5 2.5 1.1 2.5 2.5 2.5 2.5-1.1 2.5-2.5"/>
                                    </svg>
                                </div>
                                <div class="mc-unit-info">
                                    <span class="mc-unit-label">Coins Unit</span>
                                    <div class="mc-unit-btns">
                                        <button class="mc-btn mc-btn-success" t-on-click="unlockCoins" t-att-disabled="state.loading">
                                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 9.9-1"/></svg>
                                            Unlock
                                        </button>
                                        <button class="mc-btn mc-btn-warning" t-on-click="lockCoins" t-att-disabled="state.loading">
                                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                                            Lock
                                        </button>
                                    </div>
                                </div>
                            </div>


                        <!-- Notes Unit -->
                            <div class="mc-unit-strip">
                                <div class="mc-unit-icon mc-icon-blue">
                                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                        <rect x="2" y="6" width="20" height="12" rx="2"/>
                                        <circle cx="12" cy="12" r="3"/>
                                        <path d="M6 12h.01M18 12h.01"/>
                                    </svg>
                                </div>
                                <div class="mc-unit-info">
                                    <span class="mc-unit-label">Notes Unit</span>
                                    <div class="mc-unit-btns">
                                        <button class="mc-btn mc-btn-success" t-on-click="unlockNotes" t-att-disabled="state.loading">
                                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 9.9-1"/></svg>
                                            Unlock
                                        </button>
                                        <button class="mc-btn mc-btn-warning" t-on-click="lockNotes" t-att-disabled="state.loading">
                                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                                            Lock
                                        </button>
                                    </div>
                                </div>
                            </div>

                    </div>
                </div>

                <!-- ROW 2: Unit strips -->
                <div class="mc-row-units">


                    <!-- Exit Note Cover -->
                        <div class="mc-action-card mc-action-teal">
                            <div class="mc-action-icon">
                                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                    <rect x="3" y="13" width="18" height="8" rx="1.5"/>
                                    <path d="M3 13C3 13 3 7 12 7C21 7 21 13 21 13"/>
                                    <path d="M12 4v5M9.5 6.5L12 4l2.5 2.5"/>
                                </svg>
                            </div>
                            <div class="mc-action-text">
                                <span class="mc-action-title">Exit Note Cover</span>
                                <span class="mc-action-desc">Open or close the shutter</span>
                            </div>
                            <div class="mc-action-btn-pair">
                                <button class="mc-action-btn mc-action-btn-sm mc-action-btn-open" t-on-click="openExitCover" t-att-disabled="state.loading" title="Open Cover">
                                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 19V5M5 12l7-7 7 7"/></svg>
                                </button>
                                <button class="mc-action-btn mc-action-btn-sm mc-action-btn-close" t-on-click="closeExitCover" t-att-disabled="state.loading" title="Close Cover">
                                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
                                </button>
                            </div>
                        </div>

                    <!-- Reset Machine -->
                        <div class="mc-action-card mc-action-red">
                            <div class="mc-action-icon">
                                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/>
                                    <path d="M3 3v5h5"/>
                                </svg>
                            </div>
                            <div class="mc-action-text">
                                <span class="mc-action-title">Reset Machine</span>
                                <span class="mc-action-desc">Clears errors, returns to idle</span>
                            </div>
                            <button class="mc-action-btn mc-action-btn-danger" t-on-click="resetMachine" t-att-disabled="state.loading">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
                            </button>
                        </div>
                            

                </div>


            </div>

            <!-- Loading overlay -->
            <t t-if="state.loading">
                <div class="mc-overlay">
                    <div class="mc-spinner-wrap">
                        <div class="mc-spinner"/>
                        <span>Processing...</span>
                    </div>
                </div>
            </t>

        </div><!--
        /mc-root -->
    </t>
</templates>